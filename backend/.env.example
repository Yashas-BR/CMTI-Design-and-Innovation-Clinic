# FastAPI Configuration
DEBUG=True
APP_NAME="Smart Waste Dashboard API"
APP_VERSION="0.1.0"

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/smart_waste_db
DATABASE_ECHO=True

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]
CORS_CREDENTIALS=true
CORS_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS", "PATCH"]
CORS_HEADERS=["*"]

# API Configuration
API_PREFIX=/api/v1
API_TITLE="Smart Waste Dashboard API"
API_DESCRIPTION="API for Smart Waste Management System"

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Background stale checker
STALE_CHECKER_ENABLED=true
STALE_CHECK_INTERVAL_SECONDS=60
STALE_BIN_INACTIVITY_MINUTES=15

# MQTT consumer worker
MQTT_CONSUMER_ENABLED=false
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_DATA_TOPIC_PATTERN=smartbin/+/data
MQTT_ALERT_TOPIC_PATTERN=smartbin/+/alert
MQTT_USE_TLS=true
MQTT_ALLOW_INSECURE_TLS=true
MQTT_CLIENT_ID_PREFIX=smart_waste_backend
MQTT_INGEST_API_KEY=change-this-mqtt-ingest-api-key

# IoT retention worker
TELEMETRY_RETENTION_ENABLED=false
TELEMETRY_RETENTION_INTERVAL_SECONDS=3600
MQTT_RAW_RETENTION_DAYS=30
BIN_TELEMETRY_RETENTION_DAYS=180

# Notification dispatcher
NOTIFICATIONS_ENABLED=false
NOTIFICATION_IN_APP_ENABLED=true
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_FROM=noreply@smartwaste.local
NOTIFICATION_EMAIL_SMTP_HOST=
NOTIFICATION_EMAIL_SMTP_PORT=587
NOTIFICATION_EMAIL_SMTP_USE_TLS=true
NOTIFICATION_EMAIL_SMTP_USE_SSL=false
NOTIFICATION_EMAIL_SMTP_USERNAME=
NOTIFICATION_EMAIL_SMTP_PASSWORD=
NOTIFICATION_EMAIL_TIMEOUT_SECONDS=10
NOTIFICATION_EMAIL_RECIPIENT_FALLBACK=[]
NOTIFICATION_PUSH_ENABLED=false
NOTIFICATION_PUSH_PROVIDER=fcm
NOTIFICATION_PUSH_ENDPOINT=
NOTIFICATION_PUSH_API_KEY=
NOTIFICATION_PUSH_TIMEOUT_SECONDS=8
NOTIFICATION_PUSH_DEFAULT_TOPICS=[]
